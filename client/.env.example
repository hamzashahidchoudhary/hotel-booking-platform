# The client talks to the backend via the Vite dev proxy (see vite.config.js),
# which forwards /api requests to http://localhost:5000 in development.
# In production, set this to your deployed backend URL and update axios baseURL
# in src/utils/api.js accordingly, or configure a proxy/rewrite on your host.

VITE_API_BASE_URL=http://localhost:5000/api
